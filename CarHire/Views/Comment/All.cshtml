@model CommentExposeModel

@{
    ViewData["Title"] = "Driver notes";
}

@section Head {
    <link rel="stylesheet" href="~/css/editorial-comment.css" asp-append-version="true" />
}

<section class="ed-feed" aria-labelledby="ed-feed-title">
    <div class="ed-feed__inner stagger-in">

        <header class="ed-feed__head">
            <figure class="ed-feed__media">
                <img class="ed-feed__img" src="@Model.ImageUrl" alt="Vehicle" />
            </figure>

            <div class="ed-feed__headline">
                <span class="eyebrow">— Driver notes</span>
                <h1 id="ed-feed-title" class="ed-feed__title">
                    What the road <em>said back.</em>
                </h1>
                <span class="ed-feed__count" aria-label="Number of notes">
                    <strong>@Model.Comments.Count().ToString("D2")</strong> note@(Model.Comments.Count() == 1 ? "" : "s") on record
                </span>
                <a class="ed-feed__back" asp-controller="Vehicles" asp-action="Index">
                    <span aria-hidden="true">←</span>
                    <span>Back to the collection</span>
                </a>
            </div>
        </header>

        @if (Model.Comments.Any())
        {
            <ol class="ed-feed__list">
                @{ var count = 1; }
                @foreach (var comment in Model.Comments)
                {
                    <li class="ed-feed__item">
                        <span class="ed-feed__num" aria-hidden="true">№ @count.ToString("D2")</span>
                        <blockquote class="ed-feed__quote">
                            @comment.Description
                        </blockquote>
                    </li>
                    count++;
                }
            </ol>
        }
        else
        {
            <p class="ed-feed__empty">— No notes on record for this piece. Be the first to write one.</p>
        }

    </div>
</section>
