@model CommentHomeModel

@{
    ViewData["Title"] = "Leave a note";
    Model.UserName = ViewBag.UserFirstName;
}

@section Head {
    <link rel="stylesheet" href="~/css/editorial-comment.css" asp-append-version="true" />
}

<section class="ed-note" aria-labelledby="ed-note-title">
    <div class="ed-note__inner stagger-in">

        <header class="ed-note__head">
            <span class="eyebrow">— Driver's note</span>
            <h1 id="ed-note-title" class="ed-note__title">
                Tell us how it <em>drove.</em>
            </h1>
            <p class="ed-note__lede">
                A short note for the next driver — how it handled, what surprised you, whether it lived up to its part of the fleet.
            </p>
        </header>

        <form method="post" class="ed-note__form" novalidate>
            <input asp-for="@Model.VehicleId" type="hidden" />
            <input asp-for="@Model.UserId" type="hidden" />
            <input asp-for="@Model.UserName" type="hidden" />

            <div>
                <label asp-for="Description" class="visually-hidden">Your note</label>
                <textarea asp-for="Description"
                          class="ed-note__textarea"
                          rows="6"
                          placeholder="Felt like it knew the road better than I did&hellip;"></textarea>
                <span asp-validation-for="Description" class="ed-note__error"></span>
            </div>

            <div class="ed-note__actions">
                <button type="submit" class="ed-note__submit">
                    <span>Publish the note</span>
                    <span aria-hidden="true">→</span>
                </button>
                <a class="ed-note__dismiss"
                   asp-controller="Rent" asp-action="Drop" asp-route-id="@Model.VehicleId">
                    <span>Skip &amp; return piece</span>
                    <span aria-hidden="true">→</span>
                </a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
