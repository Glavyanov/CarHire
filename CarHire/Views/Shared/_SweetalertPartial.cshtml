@using static CarHire.Infrastructure.Data.ValidationConstants.MessageConstant;

@* SweetAlert2 loads at the bottom of the body, but this partial is rendered
   inside <header>. Defer the call until DOMContentLoaded so `Swal` exists
   before we fire. *@

@if (TempData[ErrorMessage] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof Swal === 'undefined') return;
            Swal.fire({
                icon: 'error',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4200,
                timerProgressBar: true,
                customClass: {
                    container: 'ed-swal__container',
                    popup: 'ed-swal__popup ed-swal__popup--error',
                    htmlContainer: 'ed-swal__body'
                },
                html: '<span class="ed-swal__eyebrow">— Off the road</span>' +
                      '<span class="ed-swal__message">@Html.Raw(Html.Encode(TempData[ErrorMessage]))</span>'
            });
        });
    </script>
}

@if (TempData[WarningMessage] != null)
{
