@using static CarHire.Infrastructure.Data.ValidationConstants.MessageConstant;

@if (TempData[ErrorMessage] != null)
{
    <script>
        (function () {
            Swal.fire({
                icon: 'error',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4200,
                timerProgressBar: true,
                customClass: {
                    container: 'ed-swal__container',
                    popup: 'ed-swal__popup ed-swal__popup--error',
                    htmlContainer: 'ed-swal__body'
                },
                html: '<span class="ed-swal__eyebrow">— Off the road</span>' +
                      '<span class="ed-swal__message">@Html.Raw(Html.Encode(TempData[ErrorMessage]))</span>'
            });
        })();
    </script>
}

@if (TempData[WarningMessage] != null)
{
    <script>
        (function () {
            Swal.fire({
                icon: 'warning',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4200,
                timerProgressBar: true,
                customClass: {
                    container: 'ed-swal__container',
                    popup: 'ed-swal__popup ed-swal__popup--warning',
                    htmlContainer: 'ed-swal__body'
                },
                html: '<span class="ed-swal__eyebrow">— Take note</span>' +
                      '<span class="ed-swal__message">@Html.Raw(Html.Encode(TempData[WarningMessage]))</span>'
            });
        })();
    </script>
}
